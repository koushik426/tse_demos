# Salesloft AI chatbot — optional LLM config.
# Without these, the chatbot uses a keyword router + small Salesloft FAQ and
# still routes data questions to ThoughtSpot Spotter.

# Anthropic API key (enables real AI answers + smart routing).
VITE_ANTHROPIC_API_KEY=

# Optional model override (default: claude-sonnet-4-6).
VITE_ANTHROPIC_MODEL=claude-sonnet-4-6
