# --- HTTP server ---
PORT=8787
# Restrict to your app's origin in production, e.g. https://app.example.com
CORS_ORIGIN=*
# Set to require the x-ingest-secret header on /api/ingest (recommended).
INGEST_SHARED_SECRET=

# --- Snowflake ---
# Account identifier, e.g. ab12345.us-east-1  (no https://, no .snowflakecomputing.com)
SF_ACCOUNT=
SF_USER=
SF_PASSWORD=
SF_WAREHOUSE=
SF_DATABASE=
SF_SCHEMA=
# Optional: override the target table name (default TS_CUSTOM_ACTION_EVENTS)
SF_TABLE=TS_CUSTOM_ACTION_EVENTS
