# ThoughtSpot cluster host (no trailing slash)
VITE_TS_HOST=https://your-cluster.thoughtspot.cloud

# Your backend ingest endpoint (NOT Snowflake directly)
VITE_INGEST_ENDPOINT=http://localhost:8787/api/ingest

# Optional: shared secret that must match the backend's INGEST_SHARED_SECRET
VITE_INGEST_SECRET=
