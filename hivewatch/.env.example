# ThoughtSpot cluster host (no trailing slash)
VITE_TS_HOST=https://team1.thoughtspot.cloud

# Optional: hosted, CSP-allowlisted theme stylesheets used as the embed's
# customCSSUrl. Host public/thoughtspot-dark.css and thoughtspot-light.css on a
# CDN (e.g. jsDelivr), allowlist the URLs in the cluster CSP (style-src), and
# set them here. Leave empty to use the built-in inline theming.
VITE_TS_DARK_CSS_URL=
VITE_TS_LIGHT_CSS_URL=
